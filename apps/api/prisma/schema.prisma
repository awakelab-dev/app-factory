// Modelo de datos de la plataforma.
// Convención (docs/02-stack.md): las entidades core viven en el schema PG "core";
// cada módulo generado añade sus modelos con su propio schema PG (multiSchema).
//
// Generador: `prisma-client` (Prisma 7, sin engines Rust). El cliente se genera
// como TypeScript en src/generated/prisma (gitignored) y consulta la BD vía
// driver adapter (@prisma/adapter-pg). Ver DECISIONES D-010.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

// Prisma 7: la URL de conexión ya no vive aquí — CLI usa prisma.config.ts
// y el runtime recibe el adapter (@prisma/adapter-pg) en el constructor.
datasource db {
  provider = "postgresql"
  schemas  = ["core", "moodle", "orientador", "proyectos", "focus"]
}

/// Usuario de la plataforma. La identidad vendrá del IdP (SSO pendiente,
/// ver STATUS); mientras tanto se crea por seed y se autentica con dev-login.
model User {
  id          String       @id @default(uuid(7)) @db.Uuid
  email       String       @unique
  displayName String
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  roles       UserRole[]
  auditEvents AuditEvent[] @relation("actor")

  @@map("users")
  @@schema("core")
}

/// Rol global de plataforma (admin, user, ...). Los permisos finos por
/// módulo viven en cada module.manifest (requiredRoles).
model Role {
  id          String     @id @default(uuid(7)) @db.Uuid
  name        String     @unique
  description String
  users       UserRole[]

  @@map("roles")
  @@schema("core")
}

/// Asignación usuario↔rol. Tabla explícita (no m-n implícita) para poder
/// auditar cuándo/quién asignó cada rol.
model UserRole {
  userId     String   @db.Uuid
  roleId     String   @db.Uuid
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("core")
}

/// Evento de auditoría append-only. `action` con convención "dominio.accion"
/// (p. ej. "auth.dev_login"). `actorId` nullable: acciones de sistema.
model AuditEvent {
  id        String   @id @default(uuid(7)) @db.Uuid
  actorId   String?  @db.Uuid
  actor     User?    @relation("actor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action, createdAt])
  @@map("audit_events")
  @@schema("core")
}

// ---------------------------------------------------------------------------
// Módulo moodle-insights (primer módulo ejemplar, D-020/D-022): réplica
// PARCIAL y de solo lectura de una única instancia Moodle (single-tenant,
// credenciales por variables de entorno — ver .env.example) vía Moodle Web
// Services. Se repuebla por completo en cada sync ("full refresh": el botón
// "Actualizar datos" reemplaza todo el contenido de estas 4 tablas dentro de
// una transacción) — nunca sincroniza en segundo plano ni por webhook.
// Volumen esperado (una instancia, no las 36 del grupo): cientos de cursos y
// alumnos, no millones de filas — el patrón full-refresh es intencionalmente
// simple para ese volumen; si un módulo futuro necesita más escala, cambiar a
// upsert+diff.
// ---------------------------------------------------------------------------

enum MoodleSyncStatus {
  running
  success
  error

  @@schema("moodle")
}

/// Un registro por cada click en "Actualizar datos": auditoría propia del
/// módulo (además de core.audit_events, que registra solo quién disparó qué).
model MoodleSyncRun {
  id              String           @id @default(uuid(7)) @db.Uuid
  status          MoodleSyncStatus @default(running)
  triggeredById   String?          @db.Uuid
  startedAt       DateTime         @default(now())
  finishedAt      DateTime?
  coursesCount    Int              @default(0)
  studentsCount   Int              @default(0)
  enrollmentsCount Int             @default(0)
  errorMessage    String?

  @@index([startedAt])
  @@map("sync_runs")
  @@schema("moodle")
}

/// Curso replicado desde `core_course_get_courses` (+ `core_course_get_categories`
/// para categoryName, que el wsfunction de cursos no trae).
model MoodleCourse {
  id           String            @id @default(uuid(7)) @db.Uuid
  moodleId     Int               @unique
  shortname    String
  fullname     String
  categoryId   Int?
  categoryName String?
  visible      Boolean           @default(true)
  startDate    DateTime?
  syncedAt     DateTime          @default(now())
  enrollments  MoodleEnrollment[]
  grades       MoodleGrade[]

  @@map("courses")
  @@schema("moodle")
}

/// Alumno replicado desde `core_enrol_get_enrolled_users` (rol student).
model MoodleStudent {
  id          String            @id @default(uuid(7)) @db.Uuid
  moodleId    Int               @unique
  fullname    String
  email       String
  syncedAt    DateTime          @default(now())
  enrollments MoodleEnrollment[]
  grades      MoodleGrade[]

  @@map("students")
  @@schema("moodle")
}

/// Matrícula curso↔alumno (rol "student" en `core_enrol_get_enrolled_users`).
model MoodleEnrollment {
  id        String        @id @default(uuid(7)) @db.Uuid
  courseId  String        @db.Uuid
  studentId String        @db.Uuid
  course    MoodleCourse  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   MoodleStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  syncedAt  DateTime      @default(now())

  @@unique([courseId, studentId])
  @@map("enrollments")
  @@schema("moodle")
}

/// Calificación total de curso por alumno, del item `itemtype = "course"` que
/// devuelve `gradereport_user_get_grade_items`.
model MoodleGrade {
  id        String        @id @default(uuid(7)) @db.Uuid
  courseId  String        @db.Uuid
  studentId String        @db.Uuid
  course    MoodleCourse  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   MoodleStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  grade     Float?
  gradeMax  Float?
  syncedAt  DateTime      @default(now())

  @@unique([courseId, studentId])
  @@map("grades")
  @@schema("moodle")
}

// ---------------------------------------------------------------------------
// Módulo orientador-ia (segundo caso real, primero de Fase 1 vía pipeline con
// spec intermedia — D-024/D-025, docs/pipeline/orientador-ia/): landing +
// orientador de carrera para el mercado laboral español, encargo de Awakelab
// para Grupo Aspasia/Refactika. Flujo público (candidato, sin login, @Public())
// + panel admin acotado al rol "orientador_admin" (D-011: rol declarado en el
// manifest del módulo, sin tocar el core). A diferencia de moodle-insights,
// el análisis por candidato es una sola llamada corta a Claude (segundos, no
// minutos) — no se justifica el patrón asíncrono con polling, la respuesta de
// POST /intake ya incluye el perfil generado.
// ---------------------------------------------------------------------------

enum OrientadorInputType {
  story
  linkedin_url
  cv_pdf

  @@schema("orientador")
}

/// Nivel declarado por el candidato o estimado por el análisis de Claude.
enum OrientadorLevel {
  inicial
  aplicada
  experto

  @@schema("orientador")
}

/// Un registro por candidato que completa el consentimiento + envía su
/// historia/CV/LinkedIn. `analysisCount` es el contador del límite de 50
/// ejecuciones por candidato (D-025) — no hay login, así que el candidato se
/// identifica por email.
model OrientadorLead {
  id               String               @id @default(uuid(7)) @db.Uuid
  createdAt        DateTime             @default(now())
  fullName         String
  email            String
  phone            String?
  consentGiven     Boolean
  consentMarketing Boolean              @default(false)
  consentAt        DateTime
  rawInputType     OrientadorInputType
  /// Texto libre, URL de LinkedIn o texto extraído del CV (client-side con
  /// pdf.js, igual que el prototipo original) — truncado a 2000 caracteres.
  rawInputText     String               @db.Text
  declaredSector   String?
  declaredLevel    OrientadorLevel?
  /// Tope anti-abuso: 50 llamadas reales a Claude por candidato (D-025), no
  /// un presupuesto de uso normal (1 análisis por persona es lo esperado).
  analysisCount    Int                  @default(0)
  profile          OrientadorProfile?

  @@index([email])
  @@map("leads")
  @@schema("orientador")
}

/// Resultado de la llamada a Claude (Haiku, D-025): reemplaza el motor de
/// keyword-matching del prototipo original como fuente de la recomendación.
model OrientadorProfile {
  id                String          @id @default(uuid(7)) @db.Uuid
  leadId            String          @unique @db.Uuid
  lead              OrientadorLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  recommendedSector String
  rationale         String          @db.Text
  estimatedLevel    OrientadorLevel
  /// Array de strings (2-3 huecos de formación) — jsonb porque es la única
  /// parte genuinamente variable/no tabular del análisis (docs/02-stack.md).
  skillGaps         Json
  llmModel          String
  llmTokensUsed     Int?
  createdAt         DateTime        @default(now())

  @@map("profiles")
  @@schema("orientador")
}

/// Contenido comercial de las 13 "academias" (una por sector). Se mantiene
/// tal cual el contenido del prototipo original (gate funcional D-025: sin
/// revisión antes de producción) — id real del prototipo como PK (no uuid)
/// para que el seed sea una copia literal y trazable de app.js del original.
model OrientadorAcademy {
  id            String   @id
  sector        String
  name          String
  shortName     String
  icon          String
  color         String
  duration      String
  durationWeeks Int
  synchronous   String
  asynchronous  String
  challenge     String   @db.Text
  /// Arrays de strings (módulos/resultados) — jsonb, mismo motivo que skillGaps.
  modules       Json
  outcomes      Json
  priceEur      String
  priceUsd      String
  purchaseUrl   String
  active        Boolean  @default(true)
  updatedAt     DateTime @updatedAt

  @@map("academies")
  @@schema("orientador")
}

/// Trazabilidad RGPD de exportaciones de leads (quién exportó cuántos y cuándo).
model OrientadorExportLog {
  id          String   @id @default(uuid(7)) @db.Uuid
  adminUserId String   @db.Uuid
  exportedAt  DateTime @default(now())
  leadCount   Int

  @@map("exports_log")
  @@schema("orientador")
}

// ---------------------------------------------------------------------------
// Módulo gestor-proyectos (spec docs/pipeline/gestor-proyectos/): tablero
// kanban de proyectos/sprints/tareas de uso 100% interno de Awakelab (sin rol
// de manifest nuevo — reutiliza `admin`/`user` de core tal cual, D-011).
// `createdById`/`assigneeId`/`authorId` son referencias conceptuales a
// `core.users` (mismo patrón que `moodle.sync_runs.triggeredById` y
// `orientador.exports_log.adminUserId`): `String @db.Uuid` SIN `@relation`
// hacia `core.User` — se resuelven a nivel de aplicación (join manual/lookup
// dentro del propio servicio, vía el mismo PrismaClient), no hay FK de base
// de datos cruzando schemas de módulo↔core. `sprintId` en `Task` es NOT NULL
// a propósito (spec funcional, pregunta 2): igual que el prototipo, no hay
// backlog sin sprint — toda tarea nace dentro de un sprint concreto.
// ---------------------------------------------------------------------------

enum ProyectosTaskStatus {
  iniciada
  en_progreso
  en_pausa
  cancelada
  finalizada

  @@schema("proyectos")
}

model Project {
  id          String   @id @default(uuid(7)) @db.Uuid
  name        String
  description String?  @db.Text
  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sprints     Sprint[]
  tasks       Task[]

  @@map("projects")
  @@schema("proyectos")
}

/// Días de calendario (`@db.Date`, no timestamptz): un sprint dura días
/// hábiles concretos, no eventos con hora — evita que la duración dependa de
/// la zona horaria de quien lo consulte (mismo motivo en `Task.dueDate`).
model Sprint {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String   @db.Uuid
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  createdAt DateTime @default(now())
  tasks     Task[]

  @@index([projectId])
  @@map("sprints")
  @@schema("proyectos")
}

model Task {
  id          String              @id @default(uuid(7)) @db.Uuid
  projectId   String              @db.Uuid
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprintId    String              @db.Uuid
  sprint      Sprint              @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  title       String
  status      ProyectosTaskStatus @default(iniciada)
  dueDate     DateTime            @db.Date
  assigneeId  String              @db.Uuid
  createdById String              @db.Uuid
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  subtasks    Subtask[]
  comments    Comment[]

  @@index([projectId])
  @@index([sprintId])
  @@index([assigneeId])
  @@map("tasks")
  @@schema("proyectos")
}

model Subtask {
  id        String   @id @default(uuid(7)) @db.Uuid
  taskId    String   @db.Uuid
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([taskId])
  @@map("subtasks")
  @@schema("proyectos")
}

model Comment {
  id        String   @id @default(uuid(7)) @db.Uuid
  taskId    String   @db.Uuid
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String   @db.Uuid
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@index([taskId])
  @@map("comments")
  @@schema("proyectos")
}

// ---------------------------------------------------------------------------
// Módulo focus-flow (spec docs/pipeline/focus-flow/): temporizador Pomodoro
// personal. Patrón de aislamiento por fila más estricto de la plataforma
// hasta ahora — dueño = `user_id` del JWT sin excepciones, ni siquiera para
// `admin` (spec funcional "Para quién", gate funcional decisión 1). Sin rol
// de manifest nuevo (D-011): cualquier `user`/`admin` autenticado accede a
// su propia cola/estadísticas.
//
// `userId`/`taskId` referencian conceptualmente `core.users`/`focus.tasks`
// (uuid, sin `@relation` hacia `core.User` para `userId` — mismo patrón que
// `proyectos.tasks.assigneeId`/`moodle.sync_runs.triggeredById`: se resuelve
// a nivel de aplicación, no hay FK de base de datos cruzando módulo↔core).
// `sourceProyectosTaskId` (gate técnico, decisión 3) es una copia de solo
// lectura del id de `proyectos.tasks` en el momento de "Importar mis tareas
// asignadas" (gate funcional, decisión 2) — NUNCA una FK ni una referencia
// viva/sincronizada; evita reimportar la misma tarea dos veces.
// ---------------------------------------------------------------------------

enum FocusSessionPhase {
  focus
  short_break
  long_break

  @@schema("focus")
}

/// Configuración personal del temporizador — una fila por usuario, creada
/// perezosamente en el primer `GET /focus-flow/settings`.
model FocusSettings {
  id                    String   @id @default(uuid(7)) @db.Uuid
  userId                String   @unique @db.Uuid
  focusMinutes          Int      @default(25)
  shortBreakMinutes     Int      @default(5)
  longBreakMinutes      Int      @default(15)
  roundsBeforeLongBreak Int      @default(4)
  autoStartBreaks       Boolean  @default(true)
  autoStartFocus        Boolean  @default(false)
  notificationsEnabled  Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("settings")
  @@schema("focus")
}

/// Cola de tareas del día. `taskDate` (`@db.Date`, día de calendario, no
/// instante) es el filtro de "hoy" por defecto — mismo motivo que
/// `proyectos.sprints.startDate/endDate` (evita que dependa de la zona
/// horaria de quien consulta). `position` es el orden dentro de su propio
/// día (arrastrar-y-soltar).
model FocusTask {
  id                    String          @id @default(uuid(7)) @db.Uuid
  userId                String          @db.Uuid
  title                 String
  estimatedPomodoros    Int             @default(1)
  completedPomodoros    Int             @default(0)
  done                  Boolean         @default(false)
  position              Int             @default(0)
  taskDate              DateTime        @db.Date
  sourceProyectosTaskId String?         @db.Uuid
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  sessions              FocusSession[]

  @@index([userId, taskDate])
  @@map("tasks")
  @@schema("focus")
}

/// Fuente de verdad de las estadísticas reales (dashboard/desempeño) —
/// reemplaza los números decorativos del prototipo (spec funcional, hallazgo
/// 2). `taskId` nullable: un descanso no tiene tarea. `onDelete: SetNull` en
/// vez de `Cascade`: borrar una tarea no debe perder el historial de
/// pomodoros ya contabilizado.
model FocusSession {
  id              String            @id @default(uuid(7)) @db.Uuid
  userId          String            @db.Uuid
  taskId          String?           @db.Uuid
  task            FocusTask?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  phase           FocusSessionPhase
  startedAt       DateTime
  completedAt     DateTime
  durationSeconds Int
  wasSkipped      Boolean           @default(false)
  createdAt       DateTime          @default(now())

  @@index([userId, completedAt])
  @@map("sessions")
  @@schema("focus")
}

/// Estado de ejecución del ciclo activo del timer — fila única por usuario
/// (mismo patrón lazy-upsert que `FocusSettings`), separada a propósito de
/// `settings`: aquí vive el estado efímero que se sobrescribe en cada acción
/// discreta del timer (play/pausa/cambio de modo/reset/fin de fase), nunca
/// por tick — el cliente sigue siendo la autoridad del conteo, esta tabla
/// solo guarda puntos de referencia para reconstruir `remainingSeconds` al
/// recargar/reabrir (spec-tecnica.md `focus-flow` change-2). `taskId` es
/// copia conceptual de `focus.tasks.id`, igual que `FocusSession.taskId`
/// pero sin FK (se resuelve a nivel de aplicación, mismo motivo que
/// `sourceProyectosTaskId`).
model FocusTimerState {
  id                 String            @id @default(uuid(7)) @db.Uuid
  userId             String            @unique @db.Uuid
  phase              FocusSessionPhase @default(focus)
  round              Int               @default(1)
  taskId             String?           @db.Uuid
  phaseStartedAt     DateTime?
  accumulatedSeconds Int               @default(0)
  running            Boolean           @default(false)
  updatedAt          DateTime          @updatedAt

  @@map("timer_state")
  @@schema("focus")
}
