# Copiar a .env para desarrollo local. NUNCA commitear .env (ver D-008 / incidente Mongo).
# Dev local: Postgres en Docker (docker-compose.dev.yml en la raíz).
# Prod: Lightsail managed PostgreSQL en modo privado (D-004).
DATABASE_URL="postgresql://awk:awk@localhost:5432/awkplatform"
PORT=3000
# Firma de los JWT de plataforma. En dev puede omitirse (usa un secreto de
# desarrollo); en producción es OBLIGATORIA (la API no arranca sin ella).
JWT_SECRET="cambia-esto-en-produccion"
