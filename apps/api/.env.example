# Copiar a .env para desarrollo local. NUNCA commitear .env (ver D-008 / incidente Mongo).
# Dev local: Postgres en Docker (docker-compose.dev.yml en la raíz).
# Prod: Lightsail managed PostgreSQL en modo privado (D-004).
DATABASE_URL="postgresql://awk:awk@localhost:5432/awkplatform"
PORT=3000
# Firma de los JWT de plataforma. En dev puede omitirse (usa un secreto de
# desarrollo); en producción es OBLIGATORIA (la API no arranca sin ella).
JWT_SECRET="cambia-esto-en-produccion"

# Módulo moodle-insights (D-020/D-022): una sola instancia Moodle, credenciales
# por variables de entorno (sin selector multi-instancia en esta v1).
# MOODLE_URL: raíz del sitio, SIN barra final (p. ej. "https://miclase.awakelab.world").
# MOODLE_TOKEN: token de un servicio externo (Administración del sitio › Servidor
# › Servicios web › Servicios externos) con estas funciones habilitadas:
#   - core_course_get_courses
#   - core_course_get_categories
#   - core_enrol_get_enrolled_users
#   - gradereport_user_get_grade_items
# Sin ambas variables, GET /api/moodle-insights/* funciona con el replicado
# vacío y POST /sync devuelve 503 (ver moodle-client.service.ts).
MOODLE_URL=""
MOODLE_TOKEN=""
# Opcional. Timeout (ms) por llamada individual a Moodle Web Services.
# Default 60000 si se omite. Súbelo si tu instancia tiene muchos cursos/
# alumnos y gradereport_user_get_grade_items tarda más (validado contra una
# instancia real de cientos de cursos el 2026-07-13, ver docs/STATUS.md).
MOODLE_REQUEST_TIMEOUT_MS=""
