# Copiar a .env para desarrollo local. NUNCA commitear .env (ver D-008 / incidente Mongo).
#
# Base de datos SEPARADA de la Plataforma (D-029): misma instancia Postgres
# managed en producción, otra base lógica ("awkfactory_staging"/"_production").
# En dev local, sobre el mismo Postgres de docker-compose.dev.yml, crear la
# base a mano una vez:
#   docker exec -it awk-db-dev psql -U awk -d awkplatform -c "CREATE DATABASE awkfactory;"
FACTORY_DATABASE_URL="postgresql://awk:awk@localhost:5432/awkfactory"

# Credenciales de Claude para el Agent SDK (headless). A diferencia de
# orientador-ia (D-024, una llamada corta a Messages API), acá el SDK lee/
# escribe archivos y corre shell en PLATFORM_REPO_PATH — mismo secreto, uso
# más amplio. Modelo por defecto: Sonnet (docs/07-metodo-de-trabajo.md,
# "desarrollo estándar sobre plantilla existente"); Haiku/Opus se configuran
# aquí sin tocar código si un caso concreto lo justifica.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# Ruta absoluta a un checkout LOCAL, limpio y dedicado del monorepo
# app-factory sobre el que corren los runners de análisis/generación (leen/
# escriben archivos, corren git/build/test). NUNCA el mismo working copy que
# un humano está editando a la vez — usar una copia aparte. En el sandbox de
# Cowork, la carpeta montada tiene restricciones de unlink/rename (D-023) que
# rompen un `git checkout -b`/`pnpm install` normal: los runners de esta fase
# están pensados para correr en un checkout fuera del mount (Mac de Leonardo
# o el Lightsail), igual que otras piezas de infra (D-016/D-023).
PLATFORM_REPO_PATH=""
