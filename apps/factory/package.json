{
  "name": "@awk/factory",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "files": ["dist"],
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "cli": "prisma generate && node --env-file-if-exists=.env -r ts-node/register/transpile-only src/cli.ts",
    "serve": "prisma generate && node --env-file-if-exists=.env --watch -r ts-node/register/transpile-only src/main.ts",
    "start": "node dist/main.js",
    "test": "prisma generate && vitest run",
    "lint": "eslint src",
    "typecheck": "prisma generate && tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.210",
    "@awk/auth": "workspace:*",
    "@awk/types": "workspace:*",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.28",
    "zod": "^4.4.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.15.6",
    "eslint": "^10.7.0",
    "prisma": "^7.8.0",
    "typescript": "~5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.10",
    "ts-node": "^10.9.2"
  }
}
