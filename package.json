    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "turbo": "^2.10.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
