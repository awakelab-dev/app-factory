{
  "$schema": "https://turborepo.com/schema.json",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "JWT_SECRET",
    "NODE_ENV",
    "PRISMA_*",
    "MOODLE_URL",
    "MOODLE_TOKEN",
    "MOODLE_REQUEST_TIMEOUT_MS",
    "ANTHROPIC_API_KEY",
    "ANTHROPIC_MODEL",
    "FACTORY_DATABASE_URL",
    "FACTORY_PORT",
    "PLATFORM_REPO_PATH"
  ],
  "tasks": {
    "prisma:generate": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "prisma:generate"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build", "prisma:generate"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build", "prisma:generate"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
