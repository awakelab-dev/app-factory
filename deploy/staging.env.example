# Plantilla — copiar a /opt/awkfactory/staging/.env EN EL SERVER (nunca en el repo).
# Ver docs/runbooks/lightsail-deploy.md.
#
# SIN COMILLAS en los valores: "docker run --env-file" (usado por
# deploy/scripts/migrate.sh) NO las interpreta y las pasa como parte literal
# del valor -> Prisma falla con P1013 "scheme not recognized" porque el
# string queda como '"postgresql://...'. Reproducido en el Lightsail real
# (2026-07-12). Mismo problema si se citan en JWT_SECRET.

IMAGE_TAG=latest
NODE_ENV=staging

# Puertos tentativos (18100-18103), a confirmar contra `ss -tlnp` antes del primer up.
API_PORT_HOST=18100
WEB_PORT_HOST=18101

# Managed PostgreSQL (D-004), rol de mínimo privilegio app_staging (runbook lightsail-postgres.md).
DATABASE_URL=postgresql://app_staging:<secreto>@<endpoint-managed>:5432/awkplatform_staging?sslmode=require

# Secreto de firma JWT de plataforma (D-011). Generar con: openssl rand -base64 48
JWT_SECRET=<secreto-staging>
