# Plantilla — copiar a /opt/awkfactory/staging/.env EN EL SERVER (nunca en el repo).
# Ver docs/runbooks/lightsail-deploy.md.
#
# SIN COMILLAS en los valores: "docker run --env-file" (usado por
# deploy/scripts/migrate.sh) NO las interpreta y las pasa como parte literal
# del valor -> Prisma falla con P1013 "scheme not recognized" porque el
# string queda como '"postgresql://...'. Reproducido en el Lightsail real
# (2026-07-12). Mismo problema si se citan en JWT_SECRET.

IMAGE_TAG=latest
NODE_ENV=staging

# Puertos tentativos (18100-18103), a confirmar contra `ss -tlnp` antes del primer up.
API_PORT_HOST=18100
WEB_PORT_HOST=18101
# Control plane de la Fábrica (apps/factory, D-030) — confirmar 18104 libre.
FACTORY_PORT_HOST=18104

# Managed PostgreSQL (D-004), rol de mínimo privilegio app_staging (runbook lightsail-postgres.md).
DATABASE_URL=postgresql://app_staging:<secreto>@<endpoint-managed>:5432/awkplatform_staging?sslmode=require&uselibpqcompat=true

# BD de la Fábrica (D-029): base lógica SEPARADA en la misma instancia managed,
# con su propio rol de mínimo privilegio (crear base+rol siguiendo el runbook
# lightsail-postgres.md antes del primer up del servicio factory).
FACTORY_DATABASE_URL=postgresql://app_factory_staging:<secreto>@<endpoint-managed>:5432/awkfactory_staging?sslmode=require&uselibpqcompat=true

# Secreto de firma JWT de plataforma (D-011). Generar con: openssl rand -base64 48
JWT_SECRET=<secreto-staging>

# Módulo moodle-insights (D-022), opcionales: sin ellas el módulo funciona con
# el replicado vacío. Ver apps/api/.env.example para qué funciones habilitar
# en el servicio externo de Moodle.
MOODLE_URL=<url-moodle-de-pruebas>
MOODLE_TOKEN=<token-servicio-externo>
# Opcional, default 60000 (ms) en el código si se omite. Subir en instancias
# grandes — validado contra una instancia real de cientos de cursos el
# 2026-07-13 (15000 por defecto abortaba con "aborted due to timeout").
MOODLE_REQUEST_TIMEOUT_MS=

# Módulo orientador-ia (D-024/D-025), opcional: sin ANTHROPIC_API_KEY el
# análisis de perfil (POST /intake) responde 503, el resto funciona igual.
ANTHROPIC_API_KEY=<api-key-anthropic>
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Authorization Server del conector Cowork (apps/factory, docs/08 / D-041) ──
# OAuth 2.1 con login usuario/contraseña. URLs canónicas de STAGING (minúsculas,
# sin barra final, con path). SIN COMILLAS (regla de arriba). Los tres secretos
# (JWKS/cookie keys/client secret) se generan UNA vez con:
#   pnpm --filter=@awk/factory run cli -- oauth-genkeys
# y se pegan aquí. El FACTORY_OAUTH_CLIENT_SECRET también va en el alta del
# custom connector (Advanced settings) que hace el Owner.
FACTORY_OAUTH_ISSUER=https://staging.apps.awakelab.world/factory-api/oauth
FACTORY_MCP_RESOURCE=https://staging.apps.awakelab.world/factory-api/mcp
FACTORY_OAUTH_CLIENT_ID=claude
FACTORY_OAUTH_REDIRECT_URI=https://claude.ai/api/mcp/auth_callback
FACTORY_OAUTH_CLIENT_SECRET=<oauth-genkeys>
FACTORY_OAUTH_COOKIE_KEYS=<oauth-genkeys>
FACTORY_OAUTH_JWKS=<oauth-genkeys>{"keys":[...]}
