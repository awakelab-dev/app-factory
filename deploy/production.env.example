# Plantilla — copiar a /opt/awkfactory/production/.env EN EL SERVER (nunca en el repo).
# Ver docs/runbooks/lightsail-deploy.md.
#
# SIN COMILLAS en los valores: "docker run --env-file" (usado por
# deploy/scripts/migrate.sh) NO las interpreta y las pasa como parte literal
# del valor -> Prisma falla con P1013 "scheme not recognized" porque el
# string queda como '"postgresql://...'. Reproducido en el Lightsail real
# (2026-07-12). Mismo problema si se citan en JWT_SECRET.

# IMAGE_TAG fijo (no "latest"): producción se promueve re-etiquetando a un sha
# concreto que ya pasó por staging (D-003 "promoción = re-tag de la misma imagen").
IMAGE_TAG=<sha-promovido-desde-staging>
NODE_ENV=production

# Puertos tentativos (18100-18103), a confirmar contra `ss -tlnp` antes del primer up.
API_PORT_HOST=18102
WEB_PORT_HOST=18103

# Managed PostgreSQL (D-004), rol de mínimo privilegio app_production (runbook lightsail-postgres.md).
DATABASE_URL=postgresql://app_production:<secreto>@<endpoint-managed>:5432/awkplatform_production?sslmode=require&uselibpqcompat=true

# Secreto de firma JWT de plataforma (D-011). Generar con: openssl rand -base64 48
# DISTINTO al de staging.
JWT_SECRET=<secreto-production>

# Módulo moodle-insights (D-022), opcionales: sin ellas el módulo funciona con
# el replicado vacío. Ver apps/api/.env.example para qué funciones habilitar
# en el servicio externo de Moodle.
MOODLE_URL=<url-moodle-real>
MOODLE_TOKEN=<token-servicio-externo>
